<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>noisyDOC | Sign up</title>
    <%- include('./style.ejs') %>
</head>

<body>
    <%- include('./nav') %>
        <main class="auth-shell">
            <section class="auth-card">
                <div class="auth-intro">
                    <% if (locals.message) { %>
                        <p class="text-danger"><%= locals.message %></p>
                    <% } %>
                    <p class="eyebrow">Get started</p>
                    <h1>Sign up</h1>
                    <p>Create your noisyDOC account so you can save and revisit document conversations.</p>
                </div>

                <form class="auth-form" action="/user/signup" method="post">
                    <label>
                        <span>Name</span>
                        <input type="text" name="fullName" placeholder="Your name" />
                    </label>
                    <label>
                        <span>Email</span>
                        <input type="email" name="email" placeholder="you@example.com" />
                    </label>
                    <label>
                        <span>Password</span>
                        <input type="password" name="password" placeholder="Choose a password" />
                    </label>
                    <button type="submit" class="btn btn-primary w-100">Create account</button>
                    <p class="form-footnote">Already have an account? <a href="/login">Login</a></p>
                </form>
            </section>
        </main>

        <%- include('./script') %>
</body>

</html>