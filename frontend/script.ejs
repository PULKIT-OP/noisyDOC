<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>
<script>
    const API_BASE = '/';
    let activeDocumentId = null;
    let activeDocumentName = null;

    // Helper to add messages to the chat box
    function addMessage(text, sender) {
        const chatMessages = document.getElementById('chat-messages');
        if (!chatMessages) return;

        const msgDiv = document.createElement('div');
        msgDiv.className = `message ${sender}`;
        msgDiv.textContent = text;
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function setActiveDocument(documentId, fileName) {
        activeDocumentId = documentId;
        activeDocumentName = fileName;

        const titlebar = document.querySelector('[data-chat-title]');
        if (titlebar && fileName) {
            titlebar.textContent = `📄 ${fileName}`;
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        const selectedPdfId = params.get('pdfId');
        const selectedFilename = params.get('filename');

        // 1. Home Page: CTA redirect
        const homeCta = document.getElementById('home-cta');
        if (homeCta) {
            homeCta.addEventListener('click', () => {
                window.location.href = '/login';
            });
        }

        // 2. My PDFs Page: Load PDF list
        const pdfListContainer = document.getElementById('pdf-list');
        if (pdfListContainer) {
            fetch('/my-pdfs-data') // Assuming a backend endpoint that returns JSON
                .then(res => res.json())
                .then(data => {
                    if (data.length === 0) {
                        pdfListContainer.innerHTML = '<p class="text-center w-100 muted">No documents found. Upload your first PDF!</p>';
                        return;
                    }
                    pdfListContainer.innerHTML = data.map(pdf => `
                        <article class="doc-card">
                            <span class="doc-badge">${pdf.filename}</span>
                            <small>Uploaded on ${new Date(pdf.uploadDate).toLocaleDateString()}</small>
                            <a class="btn btn-primary mt-3" href="/chat?pdfId=${encodeURIComponent(pdf.id)}&filename=${encodeURIComponent(pdf.filename)}">Chat with this PDF</a>
                        </article>
                    `).join('');
                })
                .catch(err => {
                    console.error('Error loading PDFs:', err);
                    pdfListContainer.innerHTML = '<p class="text-center w-100 text-danger">Failed to load documents.</p>';
                });
        }

        // 3. Chat Page: Upload and Chat logic
        const uploadBtn = document.getElementById('upload-btn');
        const uploadInput = document.getElementById('pdf-upload');
        const uploadSection = document.getElementById('upload-section');
        const chatSection = document.getElementById('chat-section');
        const sendBtn = document.getElementById('send-btn');
        const chatInput = document.getElementById('chat-input');

        if (selectedPdfId) {
            setActiveDocument(selectedPdfId, selectedFilename || 'Saved document');
            if (uploadSection) uploadSection.style.display = 'none';
            if (chatSection) chatSection.style.display = 'grid';
            addMessage(`Loaded ${selectedFilename || 'the saved document'}. You can chat with it now.`, 'bot');
        }

        if (uploadBtn && uploadInput) {
            uploadBtn.addEventListener('click', async () => {
                const file = uploadInput.files[0];
                if (!file) {
                    alert('Please select a file first.');
                    return;
                }

                const formData = new FormData();
                formData.append('document', file);

                try {
                    uploadBtn.textContent = 'Uploading...';
                    uploadBtn.disabled = true;

                    const response = await fetch('/chat/upload', {
                        method: 'POST',
                        body: formData
                    });

                    if (response.ok) {
                        const result = await response.json();
                        setActiveDocument(result.id, result.file || file.name);
                        uploadSection.style.display = 'none';
                        chatSection.style.display = 'grid';

                        addMessage(`Document ${file.name} uploaded! Ask me anything about it.`, 'bot');
                    } else {
                        alert('Upload failed. Please try again.');
                    }
                } catch (error) {
                    console.error('Upload error:', error);
                    alert('An error occurred during upload.');
                } finally {
                    uploadBtn.textContent = 'Upload & Start Chat';
                    uploadBtn.disabled = false;
                }
            });
        }

        if (sendBtn && chatInput) {
            sendBtn.addEventListener('click', async () => {
                const question = chatInput.value.trim();
                if (!question) return;
                if (!activeDocumentId) {
                    addMessage('Select or upload a document before starting the chat.', 'bot');
                    return;
                }

                addMessage(question, 'user');
                chatInput.value = '';

                try {
                    const response = await fetch('/chat', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ question, pdfId: activeDocumentId })
                    });

                    if (response.ok) {
                        const data = await response.json();
                        addMessage(data.answer || 'I couldn\'t find an answer in the document.', 'bot');
                    } else {
                        addMessage('Sorry, I encountered an error processing your request.', 'bot');
                    }
                } catch (error) {
                    console.error('Chat error:', error);
                    addMessage('Network error. Please try again later.', 'bot');
                }
            });
        }
    });
</script>