    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>noisyDOC | My PDFs</title>
    <%- include('./style') %>
</head>

<body>
    <%- include('./nav.ejs') %>

        <main class="page-shell">
            <section class="workspace-card">
